# 실제 보안 리스크 유발 가능성이 있는 endpoint/API key는 .env에만 저장하고 Git에는 포함하지 않는다.
# 해당 파일은 ".env.example" 이다.

# =============================================================================
# .env.example
# 목적:
# - S3 실습용 환경 변수 예시 파일
# - 실제 AWS 접근 키나 비밀값을 저장하지 않음
#
# 사용 방식:
# - 이 파일을 복사해서 .env 생성
# - .env에는 실제 값 입력
# - .env는 Git에 올리지 않음
#
# 예시:
# cp .env.example .env
# =============================================================================


# -----------------------------------------------------------------------------
# AWS 기본 실행 환경
# -----------------------------------------------------------------------------

# AWS 리전
# 서울 리전은 ap-northeast-2
AWS_REGION=ap-northeast-2

# AWS CLI 프로필명
# aws configure --profile dea-admin 으로 만든 프로필명과 맞춤
AWS_PROFILE=dea-admin


# -----------------------------------------------------------------------------
# S3 실습 버킷 설정
# -----------------------------------------------------------------------------

# S3 버킷 이름
# 전 세계에서 고유해야 함
# 예: dea-s3-lab-사용자이니셜-날짜
S3_BUCKET_NAME=dea-s3-lab-사용자이니셜-날짜

# 실습용 prefix
# S3의 폴더처럼 보이지만 실제로는 object key 앞부분 문자열임
S3_PREFIX=raw/

# 업로드할 로컬 샘플 파일 경로
LOCAL_SAMPLE_FILE=./s3-lab/hello.txt

# S3에 저장될 객체 key
# 최종 경로 예: s3://버킷명/raw/hello.txt
S3_OBJECT_KEY=raw/hello.txt


# -----------------------------------------------------------------------------
# 보안 기본값
# -----------------------------------------------------------------------------

# 퍼블릭 접근 허용 여부
# 초보 실습에서는 반드시 false 유지
S3_ALLOW_PUBLIC_ACCESS=false

# 서버 측 암호화 방식
# 기본 실습은 AES256, 즉 SSE-S3 사용
# KMS는 지금 단계에서 사용하지 않음
S3_SERVER_SIDE_ENCRYPTION=AES256


# -----------------------------------------------------------------------------
# 과금 방지용 제한값
# -----------------------------------------------------------------------------

# 실습 파일 최대 크기 MB
# 초보 실습에서는 작은 텍스트/JSON/CSV만 사용
MAX_UPLOAD_SIZE_MB=1

# 대량 업로드 방지
ENABLE_BULK_UPLOAD=false

# 실습 종료 후 삭제 여부
CLEANUP_AFTER_LAB=true